[user]
  name = Baptiste Grenier
{{- if eq .chezmoi.hostname "torpedo" }}
  email = "baptiste.grenier@operas-eu.org"
{{- else }}
  email = "baptiste@bapt.name"
{{- end }}
  signingkey = 46BDC6B3DE10CB983B880095022A860ECDA18F02

[github]
  user = gwarf

[commit]
{{- if eq .chezmoi.hostname "delamain" }}
  gpgsign = false
{{- else if eq .chezmoi.hostname "assist" }}
  gpgsign = false
{{- else }}
  gpgsign = true
{{- end }}

{{- if eq .chezmoi.hostname "torpedo" }}
[credential "https://gitlab.pcss.pl"]
  helper = "!f() { echo "username=baptiste.grenier@operas-eu.org"; echo "password=$PCSS_GITLAB_TOKEN"; };f"

[credential "https://forge.bapt.name"]
  username = gwarf
{{- end }}
{{- if eq .chezmoi.hostname "assist" }}
[credential "https://github.com"]
	helper = 
	helper = !/home/linuxbrew/.linuxbrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/home/linuxbrew/.linuxbrew/bin/gh auth git-credential
{{- end }}
