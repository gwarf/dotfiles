#!/usr/bin/env bash
set -euo pipefail

# systemd user services have minimal PATH; chezmoi (linuxbrew) needs explicit reach.
export PATH="/home/linuxbrew/.linuxbrew/bin:$HOME/.linuxbrew/bin:$HOME/.local/bin:$PATH"

REPOS=(
  "$HOME/.claude"
  "$HOME/.local/share/chezmoi"
)

TG_ENV="$HOME/.env"
CHAT_ID="-1003961816258"

# Telegram notifications are optional — only load the token if ~/.env exists
# AND defines TELEGRAM_BOT_TOKEN. Hosts without the env file (or without the
# token) still get a working sync; they just don't get notifications.
BOT_TOKEN=""
if [ -f "$TG_ENV" ]; then
  BOT_TOKEN=$(grep -m1 '^TELEGRAM_BOT_TOKEN=' "$TG_ENV" | cut -d= -f2- || true)
fi

tg_notify() {
  [ -z "$BOT_TOKEN" ] && return 0
  curl -s "https://api.telegram.org/bot${BOT_TOKEN}/sendMessage" \
    -d "chat_id=${CHAT_ID}" \
    --data-urlencode "text=$1" > /dev/null 2>&1 || true
}

sync_repo() {
  local repo="$1"
  local name
  name=$(basename "$repo")
  cd "$repo" || { tg_notify "⚠️ pai-git-sync[$name]: cd failed"; return 1; }

  if ! git fetch 2>&1; then
    tg_notify "⚠️ pai-git-sync[$name]: fetch failed (SSH key unavailable?)"
    return 1
  fi

  git add -A

  if ! git diff --cached --quiet; then
    # Unattended auto-commits skip GPG signing: pinentry/YubiKey is unreachable
    # from a headless timer unit, so signing fails on cache-cold runs.
    if ! git commit --no-gpg-sign -m "auto: timed sync $(date '+%Y-%m-%d %H:%M')"; then
      tg_notify "⚠️ pai-git-sync[$name]: commit failed"
      return 1
    fi
  fi

  if ! git rebase origin/main; then
    git rebase --abort 2>/dev/null || true
    tg_notify "⚠️ pai-git-sync[$name]: rebase conflict — resolve manually"
    return 1
  fi

  if ! git push; then
    tg_notify "⚠️ pai-git-sync[$name]: push failed"
    return 1
  fi

  # Post-sync hook for chezmoi: source commits don't render to target files until apply.
  # chezmoi apply is idempotent and overwrites drift — chezmoi treats source as canonical.
  if [ "$repo" = "$HOME/.local/share/chezmoi" ]; then
    if ! chezmoi apply -v 2>&1; then
      tg_notify "⚠️ pai-git-sync[$name]: chezmoi apply failed"
      return 1
    fi
  fi
}

overall=0
for repo in "${REPOS[@]}"; do
  if [ -d "$repo/.git" ]; then
    # Subshell isolates per-repo failure from set -e killing the loop.
    ( sync_repo "$repo" ) || overall=1
  else
    tg_notify "⚠️ pai-git-sync: $repo missing .git/"
    overall=1
  fi
done

exit "$overall"
