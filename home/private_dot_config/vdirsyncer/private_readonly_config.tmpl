# Synchronise mailcow from nextcloud (nextcloud is canonical)
# Triplet is [local_label, a_collection, b_collection] — a=nextcloud uses 'contacts', b=mailcow uses 'personal'
[pair nc_consolidate]
a = "nextcloud_contacts"
b = "mailcow_contacts"
collections = [["cloud_contacts", "contacts", "personal" ]]
conflict_resolution = "a wins"
metadata = ["color", "displayname"]

# Use Nextcloud as the consolidated list of contacts; mailcow is a downstream mirror
# Local mirror reads from Nextcloud directly (canonical → local → khard)
# Scoped to the real 'contacts' address book; system books (z-server-generated--*) are excluded.
[pair local_nc]
a = "local_nc_contacts"
b = "nextcloud_contacts"
collections = ["contacts"]
conflict_resolution = "b wins"
metadata = ["color", "displayname"]
{{- end }}
