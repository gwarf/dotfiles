-- Hyprland configuration (migrated from hyprlang to Lua for Hyprland 0.55+)
-- Refer to the wiki: https://wiki.hypr.land/Configuring/Start/

local mocha = require("mocha")

------------------
---- MONITORS ----
------------------
hl.monitor({
    output   = "",
    mode     = "preferred",
    position = "auto",
    scale    = "auto",
})

---------------------
---- MY PROGRAMS ----
---------------------
local terminal    = "ghostty"
local fileManager = "nautilus"
local menu        = "wofi --show drun"

-------------------
---- AUTOSTART ----
-------------------
{{ if eq .chezmoi.osRelease.id "freebsd" -}}
hl.env("SSH_AUTH_SOCK", (os.getenv("XDG_RUNTIME_DIR") or "") .. "/gcr/ssh")
hl.on("hyprland.start", function()
    hl.exec_cmd("dbus-update-activation-environment --all")
    hl.exec_cmd("/usr/local/libexec/polkit-gnome-authentication-agent-1")
    hl.exec_cmd("/usr/local/libexec/xdg-desktop-portal-hyprland")
    hl.exec_cmd("gnome-keyring-daemon --start --components=secrets,pkcs11,ssh")
    hl.exec_cmd("hypridle")
    hl.exec_cmd("waybar")
    hl.exec_cmd("swaync")
    hl.exec_cmd("hyprpaper")
    hl.exec_cmd("wl-paste --type text --watch cliphist store")
    hl.exec_cmd("wl-paste --type image --watch cliphist store")
    hl.exec_cmd(terminal)
end)
{{ else -}}
hl.on("hyprland.start", function()
    hl.exec_cmd("waybar & swaync & hyprpaper & wlsunset")
end)
{{ end }}
